# 复制为 .env 并按需修改。所有变量由 app/config.py 统一读取。
# data/ 与 .env 不提交 Git。

# ---- 访问控制（共享口令） ----
SHARED_PASSPHRASE=changeme
SESSION_SECRET=please-change-this-to-a-random-secret

# ---- LLM（OpenAI-compatible） ----
# MOCK_LLM=true 时不发网络请求，用占位输出，便于无 Key 端到端验收。
MOCK_LLM=true
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini

# ---- 转写（faster-whisper） ----
# MOCK_TRANSCRIBE=true 时返回占位转写稿，无 GPU/无模型也能跑通。
MOCK_TRANSCRIBE=true
WHISPER_MODEL_SIZE=small
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# ---- 抖音下载（第一版留桩，Cookie 环境注入，不在 UI 填） ----
DOUYIN_COOKIE=

# ---- 运行期 ----
DATA_DIR=data
UPLOAD_MAX_MB=200
MEDIA_RETENTION_DAYS=7
HOST=0.0.0.0
PORT=8000
PRODUCTION_MODE=false
